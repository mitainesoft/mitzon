[nas]
host        = 192.168.1.100
port        = 21
user        = nasuser
password    = naspassword
remote_base = /cameras

[relay]
buffer_dir      = /mnt/camhd1/ftpbuffer
transferred_dir =
# Leave transferred_dir empty to delete from buffer after NAS upload (recommended with tmpfs buffer).
# Set to a path (e.g. /mnt/camhd1/nas_transferred) to keep a local archive copy instead.
retry_dir       = /mnt/camhd1/retry
# retry_dir: disk-backed directory for files that failed NAS upload (survives reboots).
# Leave empty to disable (files stay in buffer/tmpfs and are lost on reboot if NAS is down).
retry_interval  = 30
max_connections = 10
hostname        = camftp.lan
passive_ip      = 192.168.1.50
log_file        = /var/log/ftprelay/ftprelay.log
log_max_bytes   = 5368709120
log_backup_count= 6

[camera]
user     = camuser
password = campassword

[camera_map]
MYREOLINK_00 = Falcon
MYREOLINK_01 = Cobalt
MYREOLINK_02 = Cobalt_West
MYREOLINK_03 = Ember
MYREOLINK_04 = Relay
MYREOLINK_05 = Hangar
MYREOLINK_06 = Marina
MYREOLINK_07 = GridNorth
MYREOLINK_08 = Unit_A_Media
MYREOLINK_09 = Unit_A_Office
